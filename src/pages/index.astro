---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const readingTime = (body: string) => Math.max(1, Math.round(body.split(/\s+/).length / 220));

const stats = [
  { value: '12+', label: 'Years in enterprise technology & digital transformation' },
  { value: '84%', label: 'Reduction in unresolved chatbot queries' },
  { value: '74%', label: 'Fewer enrollment inquiries via bot training' },
  { value: 'Global', label: 'Programs across GE HealthCare, GE & HCLTech' },
];

const pathways = [
  {
    title: 'Enterprise AI & AI Agents',
    desc: 'How AI agents, NLP and automation actually get deployed inside large organizations, beyond the demos.',
    href: '/blog/',
  },
  {
    title: 'HR Technology',
    desc: 'ServiceNow HRSD, Workday, portals and knowledge management, building HR service experiences that scale.',
    href: '/blog/',
  },
  {
    title: 'Chatbots & Automation',
    desc: 'Designing virtual assistants that people actually use, and measuring what matters.',
    href: '/blog/',
  },
  {
    title: 'Careers in HR Tech',
    desc: 'Lessons from 12+ years growing from frontline support to leading global transformation programs.',
    href: '/about/',
  },
];
---

<BaseLayout
  title="Aditya Singh Bhau | Digital Transformation & Enterprise AI"
  description="Digital transformation and enterprise AI professional with 12+ years across ServiceNow, Workday, AI agents, chatbots, automation and knowledge management. Articles and insights on enterprise technology that actually works."
>
  <!-- Hero -->
  <section class="section hero">
    <div class="container">
      <span class="eyebrow">Digital Transformation · Enterprise AI · Automation</span>
      <h1>
        Hi, I'm Aditya. I help global enterprises make
        <span class="mark">AI and technology</span> work for people.
      </h1>
      <p class="lead">
        For 12+ years I've worked on enterprise technology and service transformation at GE HealthCare, GE and
        HCLTech, deploying ServiceNow, AI agents, chatbots and knowledge platforms that serve
        employees worldwide. Here I share what actually works.
      </p>
      <div class="flex flex-wrap hero-cta">
        {posts.length > 0 && <a href="/blog/" class="btn btn-primary">Read my articles</a>}
        <a href="/experience/" class="btn btn-secondary">View my experience</a>
      </div>

      <div class="grid grid-4 stats reveal">
        {stats.map(({ value, label }) => (
          <div class="stat">
            <div class="stat-value">{value}</div>
            <div class="stat-label text-muted">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Companies -->
  <section class="companies">
    <div class="container text-center">
      <p class="eyebrow">Experience with</p>
      <div class="flex flex-wrap company-row">
        <span class="company"><img class="company-logo" src="/logos/ge-healthcare.svg" alt="GE HealthCare" width="140" height="35" /></span>
        <span class="company"><img class="company-logo logo-square" src="/logos/general-electric.svg" alt="General Electric" width="48" height="48" /></span>
        <span class="company"><img class="company-logo" src="/logos/hcltech.svg" alt="HCLTech" width="140" height="35" /></span>
        <span class="company"><img class="company-logo logo-square" src="/logos/dell.svg" alt="Dell" width="48" height="48" /></span>
      </div>
    </div>
  </section>

  <!-- Pathways -->
  <section class="section section-alt">
    <div class="container">
      <span class="eyebrow">What I write about</span>
      <h2>How can I help you?</h2>
      <div class="grid grid-2 pathway-grid">
        {pathways.map(({ title, desc, href }) => (
          <a href={href} class="card reveal">
            <h3>{title}</h3>
            <p class="text-muted">{desc}</p>
            <span class="pathway-link">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About teaser -->
  <section class="section">
    <div class="container about-teaser">
      <div>
        <span class="eyebrow">About me</span>
        <h2>From frontline support to global AI programs</h2>
        <p class="text-muted">
          I started in technical support at Dell in 2013. Today I work on global
          service-enablement technology at GE HealthCare, spanning ServiceNow HRSD, Agentic AI,
          chatbot ecosystems and knowledge platforms used by employees around the world.
        </p>
        <p class="text-muted">
          Along the way I've helped navigate one of the largest corporate separations in history,
          reduced unresolved chatbot queries by 84%, and built playbooks that keep global shared
          services running.
        </p>
        <a href="/about/" class="btn btn-secondary">Read my full story</a>
      </div>
      <div class="about-highlights card">
        <h3>Currently focused on</h3>
        <ul>
          <li>ServiceNow HRSD readiness & Knowledge + AI content migration</li>
          <li>Agentic AI and chatbot expansion for HR service channels</li>
          <li>AI-assisted content review and service automation</li>
          <li>Global HR portal governance and adoption strategy</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Latest articles -->
  {posts.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <div class="flex flex-wrap section-head">
          <div>
            <span class="eyebrow">Latest insights</span>
            <h2>Recent articles</h2>
          </div>
          <a href="/blog/" class="btn btn-secondary">All articles</a>
        </div>
        <div class="grid grid-3">
          {posts.map((post) => (
            <ArticleCard
              slug={post.id}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              readingTime={readingTime(post.body ?? '')}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Newsletter -->
  <section class="section">
    <div class="container nl-center">
      <NewsletterForm />
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding-top: 5rem; }
  .hero h1 { max-width: 46rem; margin-bottom: 1.25rem; }
  .hero .lead { margin-bottom: 2rem; }
  .hero-cta { margin-bottom: 4rem; }
  .stats { border-top: 1px solid var(--border); padding-top: 2.5rem; }
  .stat-value { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; color: var(--accent); }
  .stat-label { font-size: var(--text-xs); }
  .companies { padding-block: 2.5rem; border-block: 1px solid var(--border); }
  .company-row { justify-content: center; gap: 2.5rem; margin-top: 0.75rem; }
  .company { display: inline-flex; align-items: center; }
  .company-logo { height: 2.2rem; width: auto; }
  .company-logo.logo-square { height: 3rem; }
  :global(html[data-theme='dark']) .company-logo { filter: brightness(0) invert(0.9); }
  .pathway-grid { margin-top: 2rem; }
  .pathway-grid h3 { margin-bottom: 0.5rem; }
  .pathway-grid p { font-size: var(--text-sm); margin-bottom: 1rem; }
  .pathway-link { font-weight: 600; font-size: var(--text-sm); color: var(--accent); }
  .about-teaser { display: grid; grid-template-columns: 1.2fr 1fr; gap: 3rem; align-items: start; }
  .about-teaser h2 { margin-bottom: 1rem; }
  .about-teaser p { margin-bottom: 1rem; }
  .about-teaser .btn { margin-top: 0.5rem; }
  .about-highlights h3 { font-size: var(--text-lg); margin-bottom: 1rem; }
  .about-highlights ul { padding-left: 1.1rem; }
  .about-highlights li { margin-bottom: 0.6rem; font-size: var(--text-sm); color: var(--muted); }
  .section-head { justify-content: space-between; margin-bottom: 2rem; }
  .nl-center { display: flex; justify-content: center; }
  @media (max-width: 820px) { .about-teaser { grid-template-columns: 1fr; } }
</style>
