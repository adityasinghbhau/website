---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

const topics = [
  { title: 'AI agents in the real world', desc: 'What enterprise AI agent deployments actually look like: wins, failures and lessons.' },
  { title: 'HR technology that works', desc: 'ServiceNow HRSD, Workday, portals and knowledge management from the trenches.' },
  { title: 'Automation playbooks', desc: 'Practical frameworks for chatbots, self-service and process automation.' },
  { title: 'Career growth in tech', desc: 'How to grow into HR tech, AI and transformation leadership roles.' },
];
---

<BaseLayout
  title="Newsletter | The AI at Work Brief by Aditya Singh Bhau"
  description="A free newsletter on enterprise AI, AI agents, HR technology and digital transformation, practical insights from real global deployments. No hype, no spam."
>
  <section class="section">
    <div class="container nl-hero">
      <div>
        <span class="eyebrow">Free Newsletter</span>
        <h1>The <span class="mark">AI at Work</span> Brief</h1>
        <p class="lead">
          Enterprise AI is full of noise. I write about what actually ships: AI agents, HR
          technology, chatbots and automation programs deployed for real global workforces. One
          practical email, no hype, no spam.
        </p>
        <ul class="nl-benefits">
          <li>✓ Field-tested insights, not recycled headlines</li>
          <li>✓ Frameworks and playbooks you can use at work</li>
          <li>✓ Free forever, unsubscribe anytime</li>
        </ul>
      </div>
      <NewsletterForm heading="Join the Brief" />
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>What you'll get</h2>
      <div class="grid grid-2 topics-grid">
        {topics.map(({ title, desc }) => (
          <div class="card reveal">
            <h3>{title}</h3>
            <p class="text-muted">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nl-hero { display: grid; grid-template-columns: 1.2fr 1fr; gap: 3rem; align-items: center; }
  .nl-hero h1 { margin-bottom: 1rem; }
  .nl-benefits { list-style: none; padding: 0; margin-top: 1.5rem; }
  .nl-benefits li { margin-bottom: 0.5rem; font-weight: 500; }
  .topics-grid { margin-top: 2rem; }
  .topics-grid h3 { font-size: var(--text-lg); margin-bottom: 0.5rem; }
  .topics-grid p { font-size: var(--text-sm); }
  @media (max-width: 820px) { .nl-hero { grid-template-columns: 1fr; } }
</style>
