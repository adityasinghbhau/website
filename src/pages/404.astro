---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found | Aditya Singh Bhau" description="This page doesn't exist.">
  <section class="section text-center">
    <div class="container">
      <span class="eyebrow">404</span>
      <h1>This page took a <span class="mark">wrong turn</span></h1>
      <p class="lead" style="margin-inline:auto;">
        The page you're looking for doesn't exist, but there's plenty that does.
      </p>
      <div class="flex flex-wrap" style="justify-content:center; margin-top:2rem;">
        <a href="/" class="btn btn-primary">Back home</a>
        <a href="/blog/" class="btn btn-secondary">Read articles</a>
      </div>
    </div>
  </section>
</BaseLayout>
