---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Aditya Singh Bhau"
  description="Get in touch with Aditya Singh Bhau for roles, consulting, speaking, collaborations or questions about enterprise AI and HR technology."
>
  <section class="section">
    <div class="container contact-grid">
      <div>
        <span class="eyebrow">Contact</span>
        <h1>Let's <span class="mark">talk</span></h1>
        <p class="lead">
          Whether you're a recruiter, a leader exploring AI and HR technology, or someone who wants
          to collaborate, I'd love to hear from you.
        </p>
        <div class="contact-channels">
          <div class="channel">
            <h3>Email</h3>
            <a href="mailto:adityasinghbhau@gmail.com">adityasinghbhau@gmail.com</a>
          </div>
          <div class="channel">
            <h3>LinkedIn</h3>
            <a href="https://www.linkedin.com/in/adityabhau" rel="noopener" target="_blank">linkedin.com/in/adityabhau</a>
          </div>
          <div class="channel">
            <h3>Hiring?</h3>
            <p class="text-muted">Browse my <a href="/experience/">experience</a>.</p>
          </div>
        </div>
      </div>

      <!-- To activate: create a free form at formspree.io and replace xqevoldv -->
      <form class="card contact-form" action="https://formspree.io/f/xqevoldv" method="POST">
        <h2>Send a message</h2>
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div>
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required autocomplete="name" />
        </div>
        <div>
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div>
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send message</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3.5rem; align-items: start; }
  .contact-grid h1 { margin-bottom: 1rem; }
  .contact-channels { margin-top: 2.5rem; display: flex; flex-direction: column; gap: 1.5rem; }
  .channel h3 { font-size: var(--text-base); font-family: var(--font-body); font-weight: 600; margin-bottom: 0.25rem; }
  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .contact-form h2 { font-size: var(--text-xl); }
  .contact-form .btn { align-self: flex-start; }
  @media (max-width: 820px) { .contact-grid { grid-template-columns: 1fr; } }
</style>
